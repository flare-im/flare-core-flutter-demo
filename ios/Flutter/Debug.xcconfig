#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
#include "Generated.xcconfig"
// Rust staticlib + force_load: generated by scripts/ensure_ios_ffi_staticlib.sh.
OTHER_LDFLAGS=$(inherited) -Wl,-force_load,$(SRCROOT)/FFI/build/libflare_im_core_sdk_ffi.a -lc++
EXCLUDED_ARCHS[sdk=iphonesimulator*]=$(inherited) x86_64 i386
